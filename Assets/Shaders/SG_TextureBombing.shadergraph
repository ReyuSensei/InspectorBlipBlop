        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "hash22",
    "m_FunctionSource": "",
    "m_FunctionBody": "float3 p3 = frac(float3(_in.xyx) * float3(.1031, .1030, .0973));\r\np3 += dot(p3, p3.yzx+33.33);\r\n_out =  frac((p3.xx+p3.yz)*p3.zy);\n\n"
}

